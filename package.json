{
  "name": "public-meeting-follow-up-kit",
  "version": "0.1.0",
  "private": true,
  "description": "Public Meeting Follow-Up Kit turns approved meeting records into draft summaries, action trackers, FAQs, and communications plans.",
  "license": "UNLICENSED",
  "engines": {
    "node": ">=24 <25",
    "npm": ">=10"
  },
  "scripts": {
    "predev": "npm run sync:static",
    "dev": "next dev --turbo",
    "build": "next build",
    "start": "next start",
    "lint": "eslint . --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "check": "npm run compat:stack && npm run validate:repo && npm run format:check && npm run lint && npm run typecheck && npm run test",
    "verify": "npm run check && npm run build",
    "doctor": "node scripts/doctor.mjs",
    "bootstrap": "bash scripts/bootstrap.sh",
    "preflight": "bash scripts/preflight.sh",
    "deploy:firebase": "bash scripts/deploy-firebase.sh",
    "emulate:firebase": "firebase emulators:start --only apphosting",
    "docker:build": "docker build --tag public-meeting-kit:local .",
    "docker:run": "docker run --rm --publish 8080:8080 --env-file .env.local public-meeting-kit:local",
    "idea:new": "node scripts/new-idea.mjs",
    "prebuild": "npm run sync:static",
    "sync:static": "node scripts/sync-static-docs.mjs",
    "scan:secrets": "node scripts/scan-secrets.mjs",
    "data:demo": "node scripts/generate-demo-data.mjs",
    "validate:repo": "node scripts/validate-repo.mjs",
    "compat:stack": "node scripts/check-stack-compatibility.mjs"
  },
  "dependencies": {
    "@hookform/resolvers": "5.4.0",
    "clsx": "2.1.1",
    "echarts": "6.1.0",
    "firebase": "12.16.0",
    "firebase-admin": "14.2.0",
    "lucide-react": "1.25.0",
    "next": "15.2.9",
    "react": "19.2.7",
    "react-dom": "19.2.7",
    "react-hook-form": "7.81.0",
    "tailwind-merge": "3.6.0",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "4.12.1",
    "@eslint/eslintrc": "3.3.6",
    "@playwright/test": "1.61.1",
    "@tailwindcss/postcss": "4.3.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "7.0.0",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/node": "24.13.3",
    "@types/react": "19.2.17",
    "@types/react-dom": "19.2.3",
    "@vitest/coverage-v8": "4.1.10",
    "eslint": "9.39.5",
    "eslint-config-next": "15.2.9",
    "firebase-tools": "15.24.0",
    "jsdom": "29.1.1",
    "postcss": "8.5.21",
    "prettier": "3.9.6",
    "tailwindcss": "4.3.3",
    "typescript": "6.0.3",
    "vitest": "4.1.10"
  }
}
