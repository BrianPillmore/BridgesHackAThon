# Public app identity (safe to expose in browser bundles)
NEXT_PUBLIC_APP_NAME="Public Meeting Follow-Up Kit"
NEXT_PUBLIC_APP_DESCRIPTION="Draft public meeting summaries, action trackers, FAQs, and follow-up plans from approved records."
NEXT_PUBLIC_SITE_URL="https://public-meeting-kit.example"
NEXT_PUBLIC_DEMO_MODE="true"

# Optional local Firebase Web SDK configuration.
# Firebase App Hosting can auto-initialize this in production.
NEXT_PUBLIC_FIREBASE_API_KEY=""
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=""
NEXT_PUBLIC_FIREBASE_PROJECT_ID="bridgeshackathon"
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=""
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=""
NEXT_PUBLIC_FIREBASE_APP_ID=""

# Server-only values. Never prefix secrets with NEXT_PUBLIC_.
APP_ENV="development"
LOG_LEVEL="info"
